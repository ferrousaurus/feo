{
  "name": "feo",
  "version": "0.1.0",
  "private": true,
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "scripts": {
    "dev": "tsx --experimental-ffi --watch src/index.ts",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build:check": "tsgo --noEmit",
    "build": "rolldown -c",
    "start": "node --experimental-ffi dist/bundle.js"
  },
  "dependencies": {
    "@cliffy/command": "npm:@jsr/cliffy__command@^1.2.1",
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "@std/collections": "npm:@jsr/std__collections@^1.2.0",
    "@std/json": "npm:@jsr/std__json@^1.1.0",
    "@std/jsonc": "npm:@jsr/std__jsonc@^1.0.2",
    "@std/toml": "npm:@jsr/std__toml@^1.0.11",
    "@std/yaml": "npm:@jsr/std__yaml@^1.1.1",
    "@tanstack/react-query": "^5.101.0",
    "react": "^19.2.7",
    "tsx": "^4.22.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@typescript/native-preview": "7.0.0-dev.20260616.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "rolldown": "^1.1.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "^26.3.0",
    "pnpm": "^11.7.0"
  },
  "packageManager": "pnpm@11.7.0"
}
