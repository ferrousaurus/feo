{
  "name": "feo",
  "version": "0.1.0",
  "private": true,
  "os": [
    "darwin",
    "linux"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "tsc -b",
    "build": "bun build --compile --outfile=dist/feo src/index.ts"
  },
  "dependencies": {
    "@cliffy/command": "npm:@jsr/cliffy__command@^1.2.1",
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "@std/collections": "npm:@jsr/std__collections@^1.2.0",
    "@std/ini": "npm:@jsr/std__ini@^0.225.2",
    "@std/json": "npm:@jsr/std__json@^1.1.0",
    "@std/jsonc": "npm:@jsr/std__jsonc@^1.0.2",
    "@std/toml": "npm:@jsr/std__toml@^1.0.11",
    "@std/yaml": "npm:@jsr/std__yaml@^1.1.1",
    "@tanstack/react-query": "^5.101.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": "^1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
